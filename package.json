{
  "name": "wiz-action",
  "version": "0.0.0",
  "type": "module",
  "description": "Action to run the Wiz CLI and format/report results",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && ncc build lib/main.js && sed -i 's/\\x0D$//' ./dist/index.js",
    "format": "prettier --write \"**/*.ts\"",
    "format-check": "prettier --check \"**/*.ts\"",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freckle/wiz-action.git"
  },
  "author": "Freckle",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/http-client": "^4.0.0",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@actions/glob": "^0.6.1",
    "@octokit/plugin-rest-endpoint-methods": "^17.0.0",
    "@octokit/types": "^16.0.0",
    "@types/node": "^24.12.2",
    "@vercel/ncc": "^0.38.4",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
